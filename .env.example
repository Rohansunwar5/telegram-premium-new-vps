# Copy to .env and fill in real values. NEVER commit the filled-in .env.
# All values below are placeholders — keys only, no secrets.

# --- Core ---
NODE_ENV=development
PORT=4010
SERVER_NAME=telegram-premium
MONGO_URI=
ALLOWED_ORIGIN=http://localhost:5173

# --- Auth / JWT (use DISTINCT random values for the two secrets) ---
JWT_SECRET=
ADMIN_JWT_SECRET=
JWT_CACHE_ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRY=24h

# --- Redis (Bull queues + cache) ---
REDIS_LOCAL_HOST=127.0.0.1
REDIS_LOCAL_PORT=6379

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
AUTO_CLEANUP_S3=false

# --- Email (Gmail app password) ---
GMAIL_USER=
GMAIL_PASSWORD=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_DECOY_MODEL=gpt-4o-mini
OPEN_API_URL=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Telegram ---
TG_DEV_API_KEY=
DECOY_BOT_ENABLED=true

# --- bkpsch scraper ---
BKPSCH_TARGET_URL=https://www.tgdb.org/bot
BKPSCH_HEADLESS=true
BKPSCH_TIMEOUT_NAVIGATION=30000
BKPSCH_TIMEOUT_SELECTOR=10000
BKPSCH_AUTH_FILE_PATH=auth/bkpsch.auth.json
BKPSCH_CHROME_DATA_DIR=auth/bkpsch.chrome_data
BKPSCH_FALLBACK_RETRY_DELAY_MS=
BKPSCH_FALLBACK_TIMEOUT_MS=
BKPSCH_FALLBACK_TOTAL_TIMEOUT_MS=
PROXY_REQUEST_TOTAL_TIMEOUT_MS=
